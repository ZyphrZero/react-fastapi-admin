# =============================================================================
# React FastAPI Admin Docker Environment Configuration
# =============================================================================
# Copy this file to .env and modify as needed:
#   cp .env.example .env
#
# Then start with:
#   docker compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Host Port Mapping
# -----------------------------------------------------------------------------
BIND_HOST=0.0.0.0
APP_PORT=8080

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_ENV=prod
VERSION=0.1.0
APP_TITLE=React FastAPI Admin
PROJECT_NAME=React FastAPI Admin
APP_DESCRIPTION=Modern admin system built with FastAPI and React
DEBUG=false
HOST=0.0.0.0
PORT=9999
SERVER_RELOAD=false
TZ=Asia/Shanghai

# When the frontend is served by the same container, the default can stay permissive.
# If you expose the API to other origins, replace this with a JSON array.
# Example:
# CORS_ORIGINS=["https://admin.example.com"]
CORS_ORIGINS=["*"]

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
SECRET_KEY=replace_with_a_secure_random_64_char_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_COOKIE_SECURE=true
REFRESH_TOKEN_COOKIE_SAMESITE=lax

# -----------------------------------------------------------------------------
# Initial Admin Account
# -----------------------------------------------------------------------------
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_NICKNAME=admin
INITIAL_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
DB_CONNECTION=postgres

POSTGRES_USER=react_fastapi_admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=react_fastapi_admin

# -----------------------------------------------------------------------------
# Optional Runtime Controls
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60

PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=true

REDIS_ENABLE=false
